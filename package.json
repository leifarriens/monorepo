{
  "name": "@la/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "No Frameworks included Typescript Monorepo Template with Linter, Tests & CI",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "format": "prettier . --write --cache --cache-location .cache/.prettiercache",
    "build": "turbo build --continue",
    "lint": "turbo lint --continue",
    "lint:fix": "turbo lint --continue -- --fix",
    "postinstall": "sherif",
    "lint:ws": "sherif",
    "test": "turbo test",
    "typecheck": "turbo typecheck --continue",
    "turbo": "turbo"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.8.0",
    "sherif": "^1.0.0",
    "turbo": "^2.9.1"
  },
  "author": "Leif Arriens",
  "license": "MIT",
  "sherif": {
    "ignoreRule": [
      "non-existant-packages"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
